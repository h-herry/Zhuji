agent.service_name=${SW_SERVICE_NAME:user-org-service}
agent.namespace=${SW_NAMESPACE:zhuji}
agent.sample_n_per_3_secs=${SW_SAMPLE_N_PER_3_SECS:-1}
agent.authentication=${SW_AUTHENTICATION:}
agent.span_limit=${SW_SPAN_LIMIT:2000}
agent.ignore_suffix=${SW_IGNORE_SUFFIX:.jpg,.jpeg,.png,.gif,.css,.js,.html,.htm}
agent.is_open_debugging_class=${SW_IS_OPEN_DEBUGGING_CLASS:false}
agent.active_v2_header=${SW_ACTIVE_V2_HEADER:true}
agent.active_v1_header=${SW_ACTIVE_V1_HEADER:false}
agent.instance_properties_json=${SW_INSTANCE_PROPERTIES_JSON:}

collector.backend_service=${SW_COLLECTOR_BACKEND_SERVICE:localhost:11800}
collector.grpc_channel_check_interval=${SW_GRPC_CHANNEL_CHECK_INTERVAL:5}
collector.grpc_channel_timeout=${SW_GRPC_CHANNEL_TIMEOUT:10000}

logging.level=${SW_LOGGING_LEVEL:INFO}
logging.file_name=${SW_LOGGING_FILE_NAME:skywalking-api.log}
logging.dir=${SW_LOGGING_DIR:}
logging.max_file_size=${SW_LOGGING_MAX_FILE_SIZE:300}
logging.max_file_num=${SW_LOGGING_MAX_FILE_NUM:3}

plugin.mount=${SW_MOUNT:plugins,activations}
plugin.bootstrap_plugins=${SW_BOOTSTRAP_PLUGINS:}
plugin.exclude_activated_plugins=${SW_EXCLUDE_ACTIVATED_PLUGINS:}

profile.active=${SW_PROFILE_ACTIVE:false}
profile.max_tracing_duration=${SW_PROFILE_MAX_TRACING_DURATION:10}
profile.num_segments_to_store=${SW_PROFILE_NUM_SEGMENTS_TO_STORE:100}
profile.force_flush_interval=${SW_PROFILE_FORCE_FLUSH_INTERVAL:10}

meter.active=${SW_METER_ACTIVE:false}
meter.report_interval=${SW_METER_REPORT_INTERVAL:20}

trace.ignore_operation=${SW_TRACE_IGNORE_OPERATION:}