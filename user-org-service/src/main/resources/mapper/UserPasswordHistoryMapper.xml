<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhuji.userorg.mapper.UserPasswordHistoryMapper">

    <select id="selectRecentByUserId" resultType="com.zhuji.userorg.entity.UserPasswordHistory">
        SELECT * FROM sys_user_password_history
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

</mapper>
